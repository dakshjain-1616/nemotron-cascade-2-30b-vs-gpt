# Arduino AI Battle - Environment Variables
# Copy to .env and fill in your keys: cp .env.example .env

# ─── OpenRouter (easiest — one key runs both models) ──────────────────────────
# Get your key at https://openrouter.ai — gives access to both Nemotron and GPT
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── NVIDIA / Nemotron (alternative to OpenRouter) ───────────────────────────
# API key for NVIDIA NIM inference (https://build.nvidia.com)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NVIDIA API base URL (default: official NIM endpoint)
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# Nemotron model name
NEMOTRON_MODEL=nvidia/nemotron-4-340b-instruct

# ─── OpenAI / GPT ─────────────────────────────────────────────────────────────
# API key for OpenAI (https://platform.openai.com)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API base URL (default: official endpoint)
OPENAI_API_BASE=https://api.openai.com/v1

# GPT model name
OPENAI_MODEL=gpt-4.1-nano

# ─── Arduino CLI ──────────────────────────────────────────────────────────────
# Path to arduino-cli binary (uses PATH if not set)
ARDUINO_CLI_PATH=arduino-cli

# Arduino board FQBN for compilation checks
ARDUINO_FQBN=arduino:avr:uno

# Compilation timeout in seconds
ARDUINO_COMPILE_TIMEOUT=30

# ─── Scraper ──────────────────────────────────────────────────────────────────
# Arduino forum base URL
ARDUINO_FORUM_URL=https://forum.arduino.cc

# Number of bugs to fetch per scrape run (overridden by --count flag)
SCRAPE_COUNT=50

# Request timeout in seconds
SCRAPE_TIMEOUT=15

# Delay between forum requests (seconds, to avoid rate limiting)
SCRAPE_DELAY=1.0

# ─── Output ───────────────────────────────────────────────────────────────────
# Directory where results and HTML reports are written
OUTPUT_DIR=./results

# HTML report filename
REPORT_FILENAME=battle_report.html

# ─── General ──────────────────────────────────────────────────────────────────
# Set to "1" to enable verbose logging
DEBUG=0

# Max tokens per model response
MAX_TOKENS=1024

# Temperature for both models
TEMPERATURE=0.2
